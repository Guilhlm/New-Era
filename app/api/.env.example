DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app_db?schema=public"
# Required. Minimum 16 chars. Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-strong-random-secret"
# Optional. Defaults to 6001.
PORT=6001
# Optional. Comma-separated list. Defaults to localhost dev origins.
CORS_ORIGINS=http://localhost:6000,http://localhost:6002
# Optional. Password used by the demo seed (dev only).
SEED_PASSWORD=demo-password
