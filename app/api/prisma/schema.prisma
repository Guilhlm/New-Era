// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum WalletType {
  CASH
  BANK
  CRYPTO
}

enum CardType {
  CREDIT
  DEBIT
}

enum InvestmentType {
  STOCK
  REIT
  CRYPTO
  FIXED_INCOME
  OTHER
}

model User {
  id                String             @id @default(cuid())
  photoUser         String?
  themePreference   String?
  name              String
  email             String             @unique
  birthDate         DateTime?
  phone             String?
  cpf               String?            @unique
  monthlyIncome     Decimal?           @db.Decimal(12, 2)
  disciplineLevel   Int?
  isAdmin           Boolean            @default(false)
  totalBalance      Decimal            @default(0) @db.Decimal(12, 2)
  passwordHash      String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  bodyMeasures      BodyMeasure[]
  bodyVitals        BodyVital[]
  fitnessMacroGoals FitnessMacroGoal[]
  dietMeals         DietMeal[]
  waterLogs         WaterLog[]
  workoutSessions   WorkoutSession[]
  wallets           Wallet[]
  cards             Card[]
  financialGoals    FinancialGoal[]
  monthlyExpenses   MonthlyExpense[]
  transactions      Transaction[]
  investments       Investment[]
}

model BodyMeasure {
  id                    String   @id @default(cuid())
  userId                String
  height                Decimal? @db.Decimal(5, 2)
  weight                Decimal? @db.Decimal(6, 2)
  calfRight             Decimal? @db.Decimal(6, 2)
  calfLeft              Decimal? @db.Decimal(6, 2)
  quadRight             Decimal? @db.Decimal(6, 2)
  quadLeft              Decimal? @db.Decimal(6, 2)
  waist                 Decimal? @db.Decimal(6, 2)
  abdomen               Decimal? @db.Decimal(6, 2)
  back                  Decimal? @db.Decimal(6, 2)
  chest                 Decimal? @db.Decimal(6, 2)
  shoulderCircumference Decimal? @db.Decimal(6, 2)
  neckCircumference     Decimal? @db.Decimal(6, 2)
  bicepsRight           Decimal? @db.Decimal(6, 2)
  bicepsLeft            Decimal? @db.Decimal(6, 2)
  forearmRight          Decimal? @db.Decimal(6, 2)
  forearmLeft           Decimal? @db.Decimal(6, 2)
  recordedAt            DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
}

model BodyVital {
  id                    String   @id @default(cuid())
  userId                String
  bodyFat               Decimal? @db.Decimal(6, 2)
  bodyWater             Decimal? @db.Decimal(6, 2)
  leanMass              Decimal? @db.Decimal(6, 2)
  boneMass              Decimal? @db.Decimal(6, 2)
  restingHeartRate      Int?
  maxHeartRate          Int?
  basalMetabolicRate    Int?
  hydrationLevel        Decimal? @db.Decimal(6, 2)
  sleepHours            Decimal? @db.Decimal(4, 2)
  recordedAt            DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
}

model FitnessMacroGoal {
  id         String   @id @default(cuid())
  userId     String
  fats       Decimal? @db.Decimal(8, 2)
  carbodrate Decimal? @db.Decimal(8, 2)
  protein    Decimal? @db.Decimal(8, 2)
  weightGoal Decimal? @db.Decimal(8, 2)
  calories   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DietMeal {
  id        String         @id @default(cuid())
  userId    String
  weekday   Int?
  mealDate  DateTime?
  name      String
  mealTime  String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     DietFoodItem[]

  @@index([userId, mealDate])
}

model DietFoodItem {
  id        String   @id @default(cuid())
  mealId    String
  name      String
  totalGrams Decimal? @db.Decimal(8, 2)
  calories  Int?
  fats      Decimal? @db.Decimal(8, 2)
  protein   Decimal? @db.Decimal(8, 2)
  carbodrate Decimal? @db.Decimal(8, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  meal      DietMeal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([mealId])
}

model WaterLog {
  id          String   @id @default(cuid())
  userId      String
  logDate     DateTime
  waterTotal  Decimal? @db.Decimal(8, 2)
  waterIntake Decimal? @db.Decimal(8, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, logDate])
}

model WorkoutSession {
  id             String   @id @default(cuid())
  userId         String
  weekday        Int?
  nameTraining   String
  timeMinutes    Int?
  nameMuscle     String?
  totalKilos     Decimal? @db.Decimal(8, 2)
  numberSeries   Int?
  numberRepetions Int?
  isPrimaryMuscle Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekday])
}

model Wallet {
  id           String        @id @default(cuid())
  userId       String
  name         String
  balance      Decimal       @default(0) @db.Decimal(12, 2)
  type         WalletType
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromTxns     Transaction[] @relation("FromWallet")
  toTxns       Transaction[] @relation("ToWallet")

  @@index([userId])
}

model Card {
  id         String   @id @default(cuid())
  userId     String
  nameCard   String
  limitTotal Decimal? @db.Decimal(12, 2)
  limitUsage Decimal? @db.Decimal(12, 2)
  type       CardType
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FinancialGoal {
  id           String   @id @default(cuid())
  userId       String
  title        String
  targetAmount Decimal  @db.Decimal(12, 2)
  currentAmount Decimal @default(0) @db.Decimal(12, 2)
  deadline     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deadline])
}

model MonthlyExpense {
  id        String   @id @default(cuid())
  userId    String
  title     String
  amount    Decimal  @db.Decimal(12, 2)
  category  String?
  fixed     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String
  type         TransactionType
  amount       Decimal         @db.Decimal(12, 2)
  description  String?
  category     String?
  fromWalletId String?
  toWalletId   String?
  date         DateTime
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromWallet   Wallet?         @relation("FromWallet", fields: [fromWalletId], references: [id], onDelete: SetNull)
  toWallet     Wallet?         @relation("ToWallet", fields: [toWalletId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}

model Investment {
  id           String         @id @default(cuid())
  userId       String
  name         String
  type         InvestmentType
  currentValue Decimal        @db.Decimal(12, 2)
  costValue    Decimal?       @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}
